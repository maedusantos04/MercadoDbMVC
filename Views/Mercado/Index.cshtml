@model List<MERCADO_MVC.Models.Mercado>

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Produtos do Mercado</title>
    <link rel="stylesheet" href="~/css/site.css"> </head>
<body>

    <header>
        <div class="ATIVIDADE_MVC">ATIVIDADE_MVC</div>
    </header>

    <h1>Produtos do Mercado</h1>
    <p class="total-count">Total de Produtos: @ViewBag.TotalProdutos</p>

    <div style="width: 100%; max-width: 900px; text-align: left;">
        <a asp-controller="Mercado" asp-action="Cadastro" class="btn-novo-produto">Novo Produto</a>
    </div>

    <table>
        <thead>
            <tr>
                <th>Produto</th>
                <th>Descrição</th>
                <th>Quantidade</th>
                <th>Preço</th>
                <th style="text-align: right;">Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach(var m in Model)
            {
                <tr>
                    <td>@m.Produto</td>
                    <td>@m.Descricao</td>
                    <td style="text-align: center;">@m.Quantidade</td>
                    <td style="text-align: right;">R$ @m.Preco.ToString("N2")</td>
                    <td>
                        <form class="form-excluir" asp-controller="Mercado" asp-action="Deletar" method="post" onsubmit="return confirm('Deseja realmente deletar?');">
                            <input type="hidden" value="@m.Id" name="id">   
                            <button type="submit" class="btn-excluir">Excluir</button>
                        </form>                    
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <footer>
        © 2026 - ATIVIDADE_MVC
    </footer>

</body>
</html>